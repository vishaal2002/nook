{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nook",
  "version": "0.1.0",
  "identifier": "app.nook.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Nook",
        "width": 960,
        "height": 640,
        "minWidth": 720,
        "minHeight": 520,
        "transparent": false
      }
    ],
    "macOSPrivateApi": true,
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
